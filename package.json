{
  "name": "slapr",
  "version": "0.1.2",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24 <25"
  },
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3000",
    "dev:test": "next dev -H 127.0.0.1 -p 3100",
    "dev:turbo": "next dev --turbo -H 127.0.0.1 -p 3000",
    "build": "next build",
    "build:static": "NEXT_STATIC_EXPORT=1 next build",
    "start": "node out/server.mjs",
    "serve:api": "node scripts/local-grok-server.mjs --port 3000",
    "serve:static": "python3 -m http.server 3000 --bind 127.0.0.1 --directory out",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "lint": "biome check --formatter-enabled=false --assist-enabled=false app components lib api scripts tests next.config.mjs postcss.config.js tailwind.config.ts playwright.config.ts",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "tsx --watch --test \"tests/**/*.test.ts\"",
    "test:smoke": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
