{
  "name": "slapr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3000",
    "dev:turbo": "next dev --turbo -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "python3 -m http.server 3000 --bind 127.0.0.1 --directory out",
    "serve:static": "python3 -m http.server 3000 --bind 127.0.0.1 --directory out",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
